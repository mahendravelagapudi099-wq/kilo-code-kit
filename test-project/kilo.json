{
    "version": "1.0",
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        }
    },
    "agents": {
        "defaultMode": "code"
    },
    "skills": {
        "autoLoad": true,
        "modeSpecific": true
    }
}